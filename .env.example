# Environment Variables Template
# Copy to .env.local and fill in your values

# ============================================
# Database Configuration (REQUIRED)
# ============================================

# PostgreSQL connection string
# Local: postgresql://postgres:password@localhost:5432/exam_guardian
# Replit: Automatically set
# Railway: postgresql://user:pass@railway.app:5432/db
# AWS RDS: postgresql://admin:password@instance.xxx.us-east-1.rds.amazonaws.com:5432/db
DATABASE_URL=postgresql://user:password@localhost:5432/exam_guardian

# ============================================
# Server Configuration
# ============================================

# API Server port (default: 8080)
PORT=8080

# Environment: development | production (default: development)
NODE_ENV=production

# Pino logger level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# ============================================
# Frontend Configuration
# ============================================

# Base path for frontend assets (used during build)
# LOCAL: /
# Subpath: /public
BASE_PATH=/

# API base URL for frontend
VITE_API_URL=http://localhost:8080/api

# ============================================
# Authentication (Optional)
# ============================================

# JWT secret for token signing (auto-generated if not provided)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Token expiration time (default: 24h)
JWT_EXPIRY=24h

# ============================================
# CORS Configuration (Optional)
# ============================================

# Allowed origins for CORS (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ============================================
# Email Configuration (Optional)
# ============================================

# SMTP server for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@exam-guardian.com

# ============================================
# File Upload (Optional)
# ============================================

# Maximum file upload size (bytes)
MAX_UPLOAD_SIZE=52428800  # 50MB

# Allowed file types (comma-separated MIME types)
ALLOWED_FILE_TYPES=application/pdf,image/jpeg,image/png

# ============================================
# Monitoring & Analytics (Optional)
# ============================================

# Sentry error tracking
SENTRY_DSN=https://...@sentry.io/...

# Google Analytics
GOOGLE_ANALYTICS_ID=UA-...

# ============================================
# Deployment-Specific
# ============================================

# Replit: Auto-set, no changes needed
# Docker: Already in docker-compose.yml environment section
# Vercel: Set in Vercel Dashboard > Settings > Environment Variables
# VPS: Export before starting: export DATABASE_URL=...
